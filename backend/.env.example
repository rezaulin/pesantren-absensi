# ============================================
# KONFIGURASI ENVIRONMENT - SISTEM ABSENSI PESANTREN
# ============================================
# File ini berisi contoh environment variables yang dibutuhkan
# Salin file ini menjadi .env dan isi nilainya sesuai kebutuhan

# Konfigurasi Server
PORT=3000
NODE_ENV=development

# Konfigurasi Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pesantren_absensi
DB_USER=postgres
DB_PASSWORD=your_password_here

# Konfigurasi JWT (JSON Web Token) untuk autentikasi
# Gunakan string random yang kuat untuk JWT_SECRET
JWT_SECRET=your_jwt_secret_key_here_change_this
JWT_EXPIRES_IN=24h

# Konfigurasi Upload File (untuk foto santri)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
